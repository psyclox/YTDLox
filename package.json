{
    "name": "ytdlox",
    "version": "3.4.2",
    "description": "YTDLox - Advanced Desktop YouTube Downloader",
    "main": "main.js",
    "scripts": {
        "start": "npx --no electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.psyclox.ytdlox",
        "productName": "YTDLox",
        "compression": "maximum",
        "files": [
            "main.js",
            "preload.js",
            "index.html",
            "css/**/*",
            "js/**/*",
            "node_modules/**/*",
            "!node_modules/electron/**",
            "!node_modules/electron-*/**",
            "!node_modules/app-builder-*/**",
            "!node_modules/7zip-bin/**",
            "!node_modules/dmg-builder/**",
            "!node_modules/@electron/**",
            "!node_modules/postject/**",
            "!node_modules/youtube-dl-exec/bin/**",
            "!node_modules/ffmpeg-static/ffmpeg*"
        ],
        "extraResources": [
            {
                "from": "node_modules/youtube-dl-exec/bin",
                "to": "youtube-dl-bin"
            },
            {
                "from": "node_modules/ffmpeg-static",
                "to": "ffmpeg-bin",
                "filter": [
                    "ffmpeg.exe"
                ]
            }
        ],
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "directories": {
            "output": "build-output"
        }
    },
    "devDependencies": {
        "electron": "^40.6.0",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "ffmpeg-static": "^5.3.0",
        "youtube-dl-exec": "^3.1.2"
    }
}