{
    "name": "ytdlox",
    "version": "3.9.0",
    "description": "YTDLox - Advanced Desktop YouTube Downloader",
    "main": "main.js",
    "scripts": {
        "start": "cross-env ELECTRON_RUN_AS_NODE=0 electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.psyclox.ytdlox",
        "productName": "YTDLox",
        "compression": "maximum",
        "files": [
            "main.js",
            "preload.js",
            "index.html",
            "css/**/*",
            "js/**/*",
            "icons/**/*",
            "node_modules/**/*",
            "!node_modules/electron/**",
            "!node_modules/electron-*/**",
            "!node_modules/app-builder-*/**",
            "!node_modules/7zip-bin/**",
            "!node_modules/dmg-builder/**",
            "!node_modules/@electron/**",
            "!node_modules/postject/**",
            "!node_modules/youtube-dl-exec/bin/**",
            "!node_modules/ffmpeg-static/ffmpeg*",
            "!node_modules/ffprobe-static/**"
        ],
        "extraResources": [
            {
                "from": "node_modules/youtube-dl-exec/bin",
                "to": "youtube-dl-bin"
            },
            {
                "from": "node_modules/ffmpeg-static",
                "to": "ffmpeg-bin",
                "filter": [
                    "ffmpeg.exe"
                ]
            },
            {
                "from": "node_modules/ffprobe-static/bin/win32/x64",
                "to": "ffmpeg-bin",
                "filter": [
                    "ffprobe.exe"
                ]
            }
        ],
        "win": {
            "icon": "icons/ytdlox_logo.png",
            "target": [
                "portable",
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "portable": {
            "artifactName": "YTDLox-Portable-${version}.exe"
        },
        "directories": {
            "output": "releases"
        }
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "electron": "^33.4.11",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "ffmpeg-static": "^5.3.0",
        "ffprobe-static": "^3.1.0",
        "youtube-dl-exec": "^3.1.2"
    }
}
